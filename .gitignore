# --- Sistema di progetto portabile: livello privato e ignorato ---
# Fonte: .claude/templates/gitignore.snippet

# Livello privato e verboso
_notes/

# Override personali e permessi personali
CLAUDE.local.md
.claude/settings.local.json

# Estratti temporanei dei .docx (cartelle scratch)
_notes/.tmp-docx-*/
.tmp-docx-*/

# Documenti Word grezzi (binari)
# Il contenuto documentale vive nei .md tracciati; i .docx originali restano ignorati.
*.docx

# Ambiente materializzato: si versiona il manifesto, si ignora il derivato.
# Python
.venv/
__pycache__/
*.pyc
# Node
node_modules/
